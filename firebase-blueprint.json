{
  "entities": {
    "User": {
      "title": "User",
      "description": "Enterprise user profile",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "email": { "type": "string", "format": "email", "description": "User email" },
        "phoneNumber": { "type": "string", "description": "User phone number" },
        "displayName": { "type": "string", "description": "Enterprise name" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Account creation time" }
      },
      "required": ["uid", "createdAt"]
    },
    "Evaluation": {
      "title": "Evaluation",
      "description": "Saved maturity assessment result",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique evaluation ID" },
        "userId": { "type": "string", "description": "UID of the user who owns this record" },
        "totalScore": { "type": "number", "description": "Overall maturity score" },
        "level": { "type": "object", "description": "Maturity level details" },
        "dimensionScores": { "type": "array", "description": "Scores for each dimension" },
        "indicatorData": { "type": "array", "description": "Detailed indicator scores and weights" },
        "suggestions": { "type": "string", "description": "AI generated suggestions" },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the evaluation was saved" }
      },
      "required": ["id", "userId", "totalScore", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile documents"
    },
    "/evaluations/{evaluationId}": {
      "schema": "Evaluation",
      "description": "Collection of evaluation records"
    }
  }
}
